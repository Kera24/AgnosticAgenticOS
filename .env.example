# Copy to .env (git-ignored) or export in your shell / CI secrets store.
# Names only — never commit values. The doctor reports presence, never values.

# --- providers (set only the ones your roles use) ---------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Qwen or any other OpenAI-compatible endpoint
QWEN_BASE_URL=
QWEN_API_KEY=

# Ollama needs no key; override its URL only if not on localhost:11434
# AGENTIC_PROVIDER_OLLAMA_BASE_URL=http://localhost:11434/v1

# --- optional configuration overrides ---------------------------------------
# AGENTIC_EXECUTION_MODE=review
# AGENTIC_BUDGET_DAILY_LIMIT_USD=5
# AGENTIC_BUDGET_UNKNOWN_PRICE_POLICY=block
# AGENTIC_ROLE_WORKER_PROVIDER=ollama
# AGENTIC_ROLE_WORKER_MODEL=your-local-model
