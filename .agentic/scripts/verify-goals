#!/usr/bin/env python3
"""Evaluate every active standing goal. Exit 0 when all satisfied; exit 1
when any goal is violated. Results append to memory/goal-ledger.tsv."""
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

from core import goals                          # noqa: E402
from core.config import AGENTIC_DIR, load_config, repo_root  # noqa: E402


def main():
    cfg = load_config()
    violations, results = goals.check_goals(cfg, str(AGENTIC_DIR),
                                            str(repo_root(cfg)))
    if not results:
        print("(no active goals)")
        return 0
    for r in results:
        print("[%s] %s %s" % ("ok" if r["ok"] else "VIOLATED", r["id"],
                              "" if r["ok"] else "- " + r["detail"]))
    return 1 if violations else 0


if __name__ == "__main__":
    sys.exit(main())
