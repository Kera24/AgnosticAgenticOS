#!/usr/bin/env python3
"""Record or display usage ledger entries.

  python .agentic/scripts/cost-log                          show recent rows
  python .agentic/scripts/cost-log <role> <provider> <model> \
      <input_tokens> <output_tokens> [cost_usd]             append a row
"""
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

from core.budget import USAGE_COLUMNS, Budget  # noqa: E402
from core.config import AGENTIC_DIR, load_config  # noqa: E402

MEMORY = os.path.join(str(AGENTIC_DIR), "memory")


def main(argv):
    if not argv:
        path = os.path.join(MEMORY, "usage.tsv")
        if not os.path.exists(path):
            print("(no usage recorded)")
            return 0
        with open(path, encoding="utf-8") as fh:
            lines = fh.read().splitlines()
        for line in lines[-20:]:
            print(line)
        return 0
    if len(argv) in (5, 6):
        role, provider, model, tin, tout = argv[:5]
        cost = float(argv[5]) if len(argv) == 6 else 0.0
        budget = Budget(load_config(), MEMORY, "manual")
        budget.record(role, provider, model,
                      {"input_tokens": int(tin), "output_tokens": int(tout),
                       "cached_tokens": 0}, cost, "manual", "ok")
        print("recorded")
        return 0
    print(__doc__, file=sys.stderr)
    return 2


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
