#!/usr/bin/env python3
"""Trust ledger tool.

  python .agentic/scripts/trust-log                      render the ledger
  python .agentic/scripts/trust-log <skill> pass|fail    record a result
"""
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

from core.config import AGENTIC_DIR, load_config  # noqa: E402
from core.trust import TrustLedger                # noqa: E402


def main(argv):
    ledger = TrustLedger(load_config(), os.path.join(str(AGENTIC_DIR), "memory"))
    if not argv:
        print(ledger.render())
        return 0
    if len(argv) == 2 and argv[1] in ("pass", "fail"):
        before, after = ledger.record(argv[0], argv[1] == "pass")
        print("%s: %s -> %s" % (argv[0], before, after))
        return 0
    print(__doc__, file=sys.stderr)
    return 2


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
