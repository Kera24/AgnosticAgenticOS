#!/usr/bin/env python3
"""Validate dependencies, configuration, providers, repository state, and
required environment variables (presence only — never values)."""
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

from core import doctor  # noqa: E402


def main():
    ok, checks = doctor.run_doctor()
    print(doctor.render(checks))
    print("\ndoctor:", "OK" if ok else "FAILED")
    return 0 if ok else 1


if __name__ == "__main__":
    sys.exit(main())
