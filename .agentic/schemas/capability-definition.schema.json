{
  "$id": "agentic/capability-definition",
  "type": "object",
  "required": ["id", "name", "category", "description", "risk_level",
               "version"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
    "name": {"type": "string", "minLength": 1},
    "category": {"type": "string", "minLength": 1},
    "description": {"type": "string", "minLength": 1},
    "triggers": {"type": "array", "items": {"type": "string"}},
    "requirement_patterns": {"type": "array", "items": {"type": "string"}},
    "project_types": {"type": "array", "items": {"type": "string"}},
    "dependencies": {"type": "array", "items": {"type": "string"}},
    "alternatives": {"type": "array", "items": {"type": "string"}},
    "conflicts_with": {"type": "array", "items": {"type": "string"}},
    "agent_roles": {"type": "array", "items": {"type": "string"}},
    "suggested_skills": {"type": "array", "items": {"type": "string"}},
    "suggested_mcp_capabilities": {"type": "array",
                                   "items": {"type": "string"}},
    "suggested_plugins": {"type": "array", "items": {"type": "string"}},
    "deterministic_tools": {"type": "array", "items": {"type": "string"}},
    "validation_checks": {"type": "array", "items": {"type": "string"}},
    "risk_level": {"type": "string", "enum": ["low", "medium", "high"]},
    "mandatory_conditions": {"type": "array", "items": {"type": "object"}},
    "evidence_requirements": {"type": "array", "items": {"type": "string"}},
    "version": {"type": "integer", "minimum": 1}
  }
}
