{
  "$id": "agentic/capability-plan",
  "type": "object",
  "required": ["project_id", "specification_version", "taxonomy_version",
               "generated_at", "required_capabilities",
               "optional_capabilities", "inferred_capabilities",
               "rejected_capabilities", "assumptions", "dependencies",
               "conflicts", "required_agent_roles", "required_validation",
               "protected_actions", "confidence", "provenance",
               "unresolved_questions"],
  "properties": {
    "project_id": {"type": "string"},
    "specification_version": {"type": "integer", "minimum": 1},
    "taxonomy_version": {"type": "integer", "minimum": 1},
    "generated_at": {"type": "string", "minLength": 1},
    "required_capabilities": {"type": "array", "items": {
      "type": "object",
      "required": ["capability_id", "source_requirement",
                   "source_location", "reason", "mandatory",
                   "confidence", "dependencies", "acceptance_criteria",
                   "evidence_required"],
      "properties": {
        "capability_id": {"type": "string"},
        "source_requirement": {"type": "string"},
        "source_location": {"type": "string"},
        "reason": {"type": "string"},
        "mandatory": {"type": "boolean"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "dependencies": {"type": "array", "items": {"type": "string"}},
        "acceptance_criteria": {"type": "array",
                                "items": {"type": "string"}},
        "evidence_required": {"type": "array", "items": {"type": "string"}}
      }
    }},
    "optional_capabilities": {"type": "array"},
    "inferred_capabilities": {"type": "array"},
    "rejected_capabilities": {"type": "array", "items": {
      "type": "object",
      "required": ["capability_id", "reason"],
      "properties": {"capability_id": {"type": "string"},
                     "reason": {"type": "string"}}
    }},
    "assumptions": {"type": "array"},
    "dependencies": {"type": "object"},
    "conflicts": {"type": "array", "items": {
      "type": "object",
      "required": ["capability_id", "conflicts_with", "resolution"],
      "properties": {
        "capability_id": {"type": "string"},
        "conflicts_with": {"type": "string"},
        "resolution": {"type": "string"}
      }
    }},
    "required_agent_roles": {"type": "array", "items": {"type": "string"}},
    "required_validation": {"type": "array", "items": {"type": "string"}},
    "protected_actions": {"type": "array", "items": {"type": "string"}},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "provenance": {"type": "array"},
    "unresolved_questions": {"type": "array"}
  }
}
