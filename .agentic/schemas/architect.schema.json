{
  "$id": "agentic/architect",
  "type": "object",
  "required": ["architecture", "milestones", "backlog",
               "completion_criteria", "human_decisions"],
  "properties": {
    "architecture": {"type": "string", "minLength": 1},
    "assumptions": {"type": "array", "items": {"type": "string"}},
    "milestones": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"},
          "title": {"type": "string"},
          "description": {"type": "string"}
        }
      }
    },
    "backlog": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "milestone", "description", "dependencies",
                     "risk", "security_relevant", "expected_paths",
                     "expected_size", "acceptance_criteria",
                     "deterministic_checks"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"},
          "milestone": {"type": "string"},
          "description": {"type": "string", "minLength": 1},
          "dependencies": {"type": "array", "items": {"type": "string"}},
          "risk": {"type": "string", "enum": ["low", "medium", "high"]},
          "security_relevant": {"type": "boolean"},
          "expected_paths": {"type": "array", "items": {"type": "string"}},
          "expected_size": {"type": "string",
                            "enum": ["small", "medium", "large"]},
          "acceptance_criteria": {"type": "array",
                                  "items": {"type": "string"}},
          "deterministic_checks": {"type": "array",
                                   "items": {"type": "string"}},
          "skill": {"type": ["string", "null"]}
        }
      }
    },
    "requirements_map": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["requirement", "tasks"],
        "properties": {
          "requirement": {"type": "string"},
          "tasks": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "completion_criteria": {"type": "array", "items": {"type": "string"}},
    "human_decisions": {"type": "array", "items": {"type": "string"}}
  }
}
