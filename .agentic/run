#!/usr/bin/env python3
"""Agentic OS entry point.

Repository maintenance:
  python .agentic/run doctor            validate environment + configuration
  python .agentic/run tick              one maintenance workflow cycle
  python .agentic/run dry-run           analyse + work order, no edits
  python .agentic/run queue|trust|audit|goals

Multi-project registry (external application folders):
  python .agentic/run project list
  python .agentic/run project add    --name "App" --root C:\path [--plan-file plan.md]
  python .agentic/run project create --name "App" --root C:\path
  python .agentic/run project init|start|show|doctor|pause|resume|stop <id>
  python .agentic/run project archive|remove|open <id>
  python .agentic/run project relink <id> --root <new-path>
  python .agentic/run project adopt-legacy
  (bin\agentic.cmd wraps this entry point: `agentic project list`)

Full-project build:
  python .agentic/run setup             interactive machine configuration
  python .agentic/run project-start plan.md
  python .agentic/run project-run [--primary X --fallback Y --fallback Z]
  python .agentic/run project-resume | project-status | project-pause
  python .agentic/run project-review    run the final audit now
  python .agentic/run capacity          capacity ledger + next-cycle estimate
  python .agentic/run backends          backend circuit-breaker states
  python .agentic/run package           clean distributable archive
  python .agentic/run ui                local Control Centre dashboard
                                        (--port N --no-open; loopback only)

Context intelligence:
  python .agentic/run context status
  python .agentic/run context search "<query>"
  python .agentic/run context reindex
  python .agentic/run context explain <package-id>

Memory (progressive disclosure):
  python .agentic/run memory status|compact|export
  python .agentic/run memory search "<query>"
  python .agentic/run memory timeline <id>
  python .agentic/run memory show <id...>
  python .agentic/run memory forget <id>

Knowledge vault (Obsidian-compatible):
  python .agentic/run knowledge status|rebuild|validate|open

Skills (pinned, reviewed, never auto-installed):
  python .agentic/run skills list|inspect|verify|enable|disable|remove
  python .agentic/run skills add <source-dir> --revision <commit>
  python .agentic/run skills recommend <task-id>

Overrides (any command): --primary/--fallback (one run only),
--set key.path=value, --profile NAME
"""
import argparse
import json
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from core import doctor as doctor_mod          # noqa: E402
from core import goals as goals_mod            # noqa: E402
from core import queueing                      # noqa: E402
from core.budget import USAGE_COLUMNS          # noqa: E402
from core.config import AGENTIC_DIR, load_config, repo_root  # noqa: E402
from core.trust import TrustLedger             # noqa: E402

MEMORY = os.path.join(str(AGENTIC_DIR), "memory")


def _print(result):
    print(json.dumps(result, indent=2, default=str))


def cmd_doctor(cfg, args):
    ok, checks = doctor_mod.run_doctor(cfg=cfg)
    print(doctor_mod.render(checks))
    print("\ndoctor:", "OK" if ok else "FAILED")
    return 0 if ok else 1


def cmd_tick(cfg, args, dry_run=False):
    from core.orchestrator import run_tick
    result = run_tick(cfg=cfg, dry_run=dry_run)
    _print(result)
    return 0 if result.get("status") not in ("failed", "triage_failed",
                                             "conductor_failed",
                                             "worker_failed") else 1


def cmd_queue(cfg, args):
    print(queueing.render(os.path.join(str(AGENTIC_DIR), "queue")))
    return 0


def cmd_trust(cfg, args):
    print(TrustLedger(cfg, MEMORY).render())
    return 0


def cmd_audit(cfg, args):
    path = os.path.join(MEMORY, "usage.tsv")
    if not os.path.exists(path):
        print("(no API usage recorded yet)")
        return 0
    rows = []
    with open(path, encoding="utf-8") as fh:
        for line in fh:
            parts = line.rstrip("\n").split("\t")
            if len(parts) == len(USAGE_COLUMNS) and parts[0] != "timestamp":
                rows.append(dict(zip(USAGE_COLUMNS, parts)))
    totals = {}
    for r in rows[-500:]:
        key = (r["provider"], r["model"])
        t = totals.setdefault(key, {"calls": 0, "in": 0, "out": 0, "usd": 0.0})
        t["calls"] += 1
        t["in"] += int(r["input_tokens"] or 0)
        t["out"] += int(r["output_tokens"] or 0)
        t["usd"] += float(r["estimated_cost_usd"] or 0)
    print("%-14s %-30s %6s %10s %10s %10s"
          % ("PROVIDER", "MODEL", "CALLS", "IN_TOK", "OUT_TOK", "USD"))
    for (prov, model), t in sorted(totals.items()):
        print("%-14s %-30s %6d %10d %10d %10.4f"
              % (prov, model, t["calls"], t["in"], t["out"], t["usd"]))
    return 0


def cmd_goals(cfg, args):
    violations, results = goals_mod.check_goals(cfg, str(AGENTIC_DIR),
                                                str(repo_root(cfg)))
    if not results:
        print("(no active goals)")
        return 0
    for r in results:
        print("[%s] %s %s" % ("ok" if r["ok"] else "VIOLATED", r["id"],
                              "" if r["ok"] else "- " + r["detail"]))
    return 1 if violations else 0


def cmd_setup(cfg, args):
    from core.setupwiz import run_setup
    result = run_setup(cfg=cfg, smoke=not args.no_smoke)
    return 0 if result["ok"] else 1


def _overrides(args):
    if args.primary:
        return {"primary": args.primary, "fallbacks": args.fallback or []}
    return None


def cmd_project_start(cfg, args):
    from core.project import project_start
    if not args.plan:
        print("usage: project-start <plan.md>", file=sys.stderr)
        return 2
    result = project_start(cfg, args.plan, overrides=_overrides(args))
    _print(result)
    return 0 if result["status"] in ("started",) else 1


def _apply_project_overlay(cfg, args):
    """--project <id>: run the command against a registered project's
    redirected state instead of the platform-implicit project."""
    if not getattr(args, "project_id", None):
        return cfg, MEMORY
    from core import projectops
    from core.registry import ProjectRegistry
    registry = ProjectRegistry()
    record = registry.get(args.project_id)
    proj_cfg = projectops.project_cfg_for(cfg, registry, record)
    memory = os.path.join(proj_cfg["runtime"]["project_dir"], "memory")
    return proj_cfg, memory


def cmd_project_run(cfg, args):
    from core.project import project_run
    cfg, memory = _apply_project_overlay(cfg, args)
    if args.now:
        from core.scheduler import Scheduler
        Scheduler(cfg, memory).resume(force=True)
        print("cooling override: next cycle may start immediately")
    result = project_run(cfg, overrides=_overrides(args),
                         max_cycles=args.max_cycles)
    _print(result)
    return 0 if result.get("status") not in ("failure", "audit_failed") else 1


def cmd_project_resume(cfg, args):
    from core.project import project_resume, project_run
    _print(project_resume(cfg))
    result = project_run(cfg, overrides=_overrides(args), max_cycles=1)
    _print(result)
    return 0


def cmd_project_status(cfg, args):
    from core.project import project_status
    cfg, _memory = _apply_project_overlay(cfg, args)
    _print(project_status(cfg))
    return 0


def cmd_project_pause(cfg, args):
    from core.project import project_pause
    _print(project_pause(cfg))
    return 0


def cmd_project_review(cfg, args):
    from core.project import final_audit
    result = final_audit(cfg, overrides=_overrides(args))
    _print(result)
    return 0 if result["status"] == "complete" else 1


def cmd_capacity(cfg, args):
    from core.capacity import CapacityLedger, estimate_cycle_tokens
    from core import projstate
    ledger = CapacityLedger(cfg, MEMORY)
    task = projstate.next_task(AGENTIC_DIR) if projstate.exists(AGENTIC_DIR) \
        else None
    routing = cfg.get("routing") or {}
    backend = routing.get("primary", "-")
    estimate = estimate_cycle_tokens(cfg, task or {}, ledger, backend)
    _print({"next_task": (task or {}).get("id"),
            "backend": backend, "estimate": estimate,
            "recent_cycles": ledger.recent_cycles(limit=5),
            "note": "all figures are local ESTIMATES, not provider quotas"})
    return 0


def cmd_backends(cfg, args):
    from core.breaker import BreakerBoard
    if args.plan == "discover":
        from core.routing import discover
        _print(discover(cfg, MEMORY))
        return 0
    if args.plan == "decisions":
        from core.routing import read_decisions
        _print(read_decisions(MEMORY))
        return 0
    print(BreakerBoard(MEMORY).render())
    return 0


def cmd_package(cfg, args):
    """Clean distributable zip: excludes runtime artefacts, machine config,
    caches, and anything git-ignored or sensitive."""
    import zipfile
    import subprocess
    root = str(repo_root(cfg))
    out = args.plan or "agentic-os-dist.zip"
    tracked = subprocess.run(["git", "ls-files"], cwd=root,
                             capture_output=True, text=True).stdout.split("\n")
    excluded_prefixes = (".agentic/runs/", ".agentic/worktrees/",
                         ".agentic/memory/", ".pytest_cache/", "__pycache__/")
    excluded_names = (".env", ".agentic/config.machine.yaml")
    with zipfile.ZipFile(out, "w", zipfile.ZIP_DEFLATED) as zf:
        for name in tracked:
            name = name.strip()
            if not name or name in excluded_names or \
                    any(name.startswith(p) or "/__pycache__/" in name
                        for p in excluded_prefixes):
                continue
            path = os.path.join(root, name)
            if os.path.exists(path):
                zf.write(path, name)
        # ship pristine memory templates instead of local ledgers
        for tmpl, content in (
                ("STATE.md", "# Agentic OS State\n"),
                ("trust.tsv", "skill\ttotal_runs\tpasses\tfailures\t"
                 "consecutive_failures\tpass_rate\tcurrent_tier\t"
                 "last_result\tupdated_at\n")):
            zf.writestr(".agentic/memory/" + tmpl, content)
    print("wrote %s (%d files, local artefacts excluded)"
          % (out, len(zf.namelist())))
    return 0


def cmd_project(cfg, args):
    """project list|add|create|show|doctor|init|start|pause|resume|stop|
    archive|remove|relink|open|adopt-legacy|authorise-root"""
    from core import projectops
    from core.registry import ProjectRegistry, RegistryError
    registry = ProjectRegistry()
    sub = args.plan or "list"
    extra = args.extra or []
    ident = extra[0] if extra else None
    try:
        if sub == "list":
            rows = registry.list()
            if not rows:
                print("(no projects registered — use `project add` or "
                      "`project create`)")
                return 0
            print("%-24s %-12s %-4s %-3s %s"
                  % ("ID", "STATUS", "PRIO", "ON", "ROOT"))
            for r in rows:
                print("%-24s %-12s %-4s %-3s %s"
                      % (r["id"], r["status"], r.get("priority"),
                         "yes" if r.get("enabled") else "no",
                         r["root_path"]))
            return 0
        if sub in ("add", "create"):
            if not args.name or not args.root:
                print("usage: project %s --name <name> --root <path> "
                      "[--plan-file plan.md] [--priority N]" % sub,
                      file=sys.stderr)
                return 2
            record = registry.add(args.name, args.root,
                                  plan=args.plan_file or "plan.md",
                                  create=(sub == "create"),
                                  priority=args.priority or 50,
                                  allow_platform=args.allow_platform)
            if sub == "create":
                plan_path = os.path.join(record["root_path"],
                                         record["plan_path"])
                if not os.path.exists(plan_path):
                    with open(plan_path, "w", encoding="utf-8") as fh:
                        fh.write("# %s\n\nDescribe the application to "
                                 "build here.\n" % record["name"])
                _print(projectops.project_init(cfg, registry, record["id"]))
            _print(registry.get(record["id"]))
            print("\nnext: py .agentic/run project init %s" % record["id"])
            return 0
        if sub == "adopt-legacy":
            _print(projectops.adopt_legacy(
                cfg, registry, name=args.name or "platform-legacy"))
            return 0
        if sub == "authorise-root":
            if not args.root:
                print("usage: project authorise-root --root <path>",
                      file=sys.stderr)
                return 2
            _print({"authorised_roots": registry.authorise_root(args.root)})
            return 0
        record = projectops.resolve_project(registry, ident)
        pid = record["id"]
        if sub == "show":
            _print(projectops.project_status(cfg, registry, pid))
            return 0
        if sub == "doctor":
            report = projectops.project_doctor(cfg, registry, pid)
            for level, message in report["checks"]:
                print("[%s] %s" % (level, message))
            print("\nproject doctor:", "OK" if report["ok"] else "FAILED")
            return 0 if report["ok"] else 1
        if sub == "init":
            result = projectops.project_init(cfg, registry, pid)
            _print(result)
            return 0 if result["ok"] else 1
        if sub == "start":
            from core import projstate
            from core.project import project_start
            proj_cfg = projectops.project_cfg_for(cfg, registry, record)
            state_dir = proj_cfg["runtime"]["project_dir"]
            registry.update(pid, enabled=True)
            if not projstate.exists(state_dir):
                plan = projectops.find_plan(record)
                if not plan:
                    print("no plan file found; add one and re-run",
                          file=sys.stderr)
                    return 1
                result = project_start(proj_cfg, plan,
                                       overrides=_overrides(args))
                _print(result)
                if result["status"] != "started":
                    return 1
            print("project %s enabled; cycles run via the scheduler or "
                  "`project-run --project %s`" % (pid, pid))
            return 0
        if sub in ("pause", "resume", "stop"):
            from core.scheduler import Scheduler
            proj_cfg = projectops.project_cfg_for(cfg, registry, record)
            memdir = os.path.join(proj_cfg["runtime"]["project_dir"],
                                  "memory")
            scheduler = Scheduler(proj_cfg, memdir)
            if sub == "pause":
                scheduler.pause()
            elif sub == "resume":
                scheduler.resume(force=True)
                registry.update(pid, enabled=True)
            else:
                scheduler.pause()
                registry.update(pid, enabled=False)
            _print({"project": pid, "action": sub,
                    "scheduler": scheduler.state["state"],
                    "enabled": registry.get(pid)["enabled"]})
            return 0
        if sub == "archive":
            _print(registry.archive(pid))
            return 0
        if sub == "remove":
            _print(registry.remove(pid))
            return 0
        if sub == "relink":
            if not args.root:
                print("usage: project relink <id> --root <new-path>",
                      file=sys.stderr)
                return 2
            _print(registry.relink(pid, args.root,
                                   allow_platform=args.allow_platform))
            return 0
        if sub == "open":
            registry.update(pid, last_opened_at=registry.clock())
            if os.name == "nt":
                os.startfile(record["root_path"])   # noqa: S606
            else:
                import subprocess
                subprocess.Popen(["xdg-open", record["root_path"]])
            print("opened %s" % record["root_path"])
            return 0
    except RegistryError as exc:
        print("project error: %s"
              % (exc.detail if hasattr(exc, "detail") else exc),
              file=sys.stderr)
        return 1
    print("unknown project subcommand %r" % sub, file=sys.stderr)
    return 2


def cmd_fleet(cfg, args):
    """fleet [tick] | status | pause | resume — multi-project scheduler"""
    from core import fleet
    from core.registry import ProjectRegistry
    registry = ProjectRegistry()
    sub = args.plan or "status"
    if sub == "tick":
        result = fleet.run_tick(cfg, registry)
        _print({k: result[k] for k in ("start", "waiting", "states",
                                       "results", "global_pause")})
        return 0
    if sub == "status":
        slots = fleet.SlotManager(registry.home)
        _print({"global_pause":
                fleet.load_fleet_state(registry.home)["global_pause"],
                "slots": slots.usage(),
                "limits": fleet.concurrency_config(cfg),
                "recent_decisions": fleet.read_decisions(registry.home,
                                                         limit=3)})
        return 0
    if sub in ("pause", "resume"):
        state = fleet.set_global_pause(registry.home, sub == "pause")
        _print(state)
        return 0
    print("unknown fleet subcommand %r" % sub, file=sys.stderr)
    return 2


def cmd_context(cfg, args):
    """context status | search "<query>" | reindex | explain <package-id>"""
    from core.codeintel import get_adapter
    from core.config import repo_root
    from core.context.ledger import read_packages
    sub = args.plan or "status"
    extra = args.extra or []
    root = str(repo_root(cfg))
    adapter = get_adapter(cfg, root, MEMORY)
    if sub == "status":
        status = adapter.status()
        status["health"] = adapter.health_check()
        status["fallback_reason"] = getattr(adapter, "fallback_reason", None)
        status["recent_packages"] = len(read_packages(MEMORY, limit=1000))
        _print(status)
        return 0
    if sub == "search":
        if not extra:
            print("usage: context search \"<query>\"", file=sys.stderr)
            return 2
        _print(adapter.search(" ".join(extra)))
        return 0
    if sub == "reindex":
        _print(adapter.index_full())
        return 0
    if sub == "explain":
        if not extra:
            print("usage: context explain <package-id>", file=sys.stderr)
            return 2
        records = read_packages(MEMORY, package_id=extra[0])
        if not records:
            print("no package %r in the ledger" % extra[0], file=sys.stderr)
            return 1
        _print(records[-1])
        return 0
    print("unknown context subcommand %r" % sub, file=sys.stderr)
    return 2


def cmd_memory(cfg, args):
    """memory status | search "<q>" | timeline <id> | show <id...> |
    forget <id> | compact | export [path]"""
    from core.memsvc import get_memory, memory_config
    service = get_memory(cfg, MEMORY)
    sub = args.plan or "status"
    extra = args.extra or []
    if sub == "status":
        _print(service.status())
        return 0
    if sub == "search":
        if not extra:
            print("usage: memory search \"<query>\"", file=sys.stderr)
            return 2
        _print(service.search(" ".join(extra)))
        return 0
    if sub == "timeline":
        if not extra:
            print("usage: memory timeline <id>", file=sys.stderr)
            return 2
        _print(service.timeline(extra[0]))
        return 0
    if sub == "show":
        if not extra:
            print("usage: memory show <id...>", file=sys.stderr)
            return 2
        _print(service.details(extra))
        return 0
    if sub == "forget":
        if not extra:
            print("usage: memory forget <id>", file=sys.stderr)
            return 2
        deleted = service.forget(extra[0])
        _print({"forgotten": deleted})
        return 0 if deleted else 1
    if sub == "compact":
        removed = service.compact(
            int(memory_config(cfg).get("retention_days", 180)))
        _print({"removed": removed})
        return 0
    if sub == "export":
        out = extra[0] if extra else "memory-export.json"
        count = service.export(out)
        _print({"exported": count, "path": out})
        return 0
    print("unknown memory subcommand %r" % sub, file=sys.stderr)
    return 2


def cmd_skills(cfg, args):
    """skills list | inspect <id> | add <src> --revision <commit> |
    enable/disable/verify/remove <id> | review <id> | recommend <task-id>"""
    from core.skillreg import SkillError, SkillRegistry
    registry = SkillRegistry(cfg, str(AGENTIC_DIR))
    sub = args.plan or "list"
    extra = args.extra or []
    try:
        if sub == "list":
            _print([{k: s.get(k) for k in ("id", "name", "enabled",
                                           "reviewed", "risk_level",
                                           "pinned_revision", "source")}
                    for s in registry.list()])
            return 0
        if sub == "inspect":
            skill = registry.get(extra[0]) if extra else None
            if not skill:
                print("usage: skills inspect <id>", file=sys.stderr)
                return 2
            _print(skill)
            return 0
        if sub == "add":
            if not extra:
                print("usage: skills add <source-dir> --revision <commit>",
                      file=sys.stderr)
                return 2
            _print(registry.add(extra[0], revision=args.revision))
            print("installed DISABLED and UNREVIEWED; inspect, then "
                  "'skills review <id>' and 'skills enable <id>'")
            return 0
        if sub in ("enable", "disable", "verify", "remove", "review"):
            if not extra:
                print("usage: skills %s <id>" % sub, file=sys.stderr)
                return 2
            action = {"enable": registry.enable,
                      "disable": registry.disable,
                      "verify": registry.verify,
                      "remove": registry.remove,
                      "review": registry.mark_reviewed}[sub]
            _print(action(extra[0]))
            return 0
        if sub == "recommend":
            from core import projstate
            task = None
            if extra and projstate.exists(str(AGENTIC_DIR)):
                task = next((t for t in projstate.load_backlog(
                    str(AGENTIC_DIR)) if t["id"] == extra[0]), None)
            query = (task or {}).get("description") or " ".join(extra)
            _print([{k: s[k] for k in ("id", "name", "description")}
                    for s in registry.select("coder", query, limit=5)])
            return 0
    except SkillError as exc:
        print("skills error: %s" % exc, file=sys.stderr)
        return 1
    print("unknown skills subcommand %r" % sub, file=sys.stderr)
    return 2


def cmd_knowledge(cfg, args):
    """knowledge status | rebuild | validate | open"""
    from core.knowledge import KnowledgeVault
    vault = KnowledgeVault(cfg, str(AGENTIC_DIR))
    sub = args.plan or "status"
    if sub == "status":
        _print(vault.status())
        return 0
    if sub == "rebuild":
        _print(vault.rebuild())
        return 0
    if sub == "validate":
        issues = vault.validate()
        _print({"ok": not issues, "issues": issues})
        return 0 if not issues else 1
    if sub == "open":
        # explicit user action only — autonomous cycles never call this
        if os.name == "nt":
            os.startfile(vault.root)          # noqa: S606
        else:
            import subprocess
            subprocess.Popen(["xdg-open", vault.root])
        print("opened %s" % vault.root)
        return 0
    print("unknown knowledge subcommand %r" % sub, file=sys.stderr)
    return 2


def cmd_ui(cfg, args):
    from ui.serve import run_ui
    return run_ui(cfg, port=args.port,
                  open_browser=False if args.no_open else None,
                  dev_origin=args.dev)


COMMANDS = {
    "doctor": cmd_doctor, "tick": cmd_tick, "queue": cmd_queue,
    "trust": cmd_trust, "audit": cmd_audit, "goals": cmd_goals,
    "setup": cmd_setup, "project-start": cmd_project_start,
    "project-run": cmd_project_run, "project-resume": cmd_project_resume,
    "project-status": cmd_project_status, "project-pause": cmd_project_pause,
    "project-review": cmd_project_review, "capacity": cmd_capacity,
    "backends": cmd_backends, "package": cmd_package, "ui": cmd_ui,
    "context": cmd_context, "memory": cmd_memory,
    "knowledge": cmd_knowledge, "skills": cmd_skills,
    "project": cmd_project, "fleet": cmd_fleet,
}


def main(argv):
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("command", nargs="?")
    parser.add_argument("plan", nargs="?")
    parser.add_argument("extra", nargs="*")
    parser.add_argument("--primary")
    parser.add_argument("--fallback", action="append", default=[])
    parser.add_argument("--set", dest="sets", action="append", default=[])
    parser.add_argument("--profile")
    parser.add_argument("--max-cycles", type=int, default=1)
    parser.add_argument("--no-smoke", action="store_true")
    parser.add_argument("--revision")
    parser.add_argument("--now", action="store_true",
                        help="clear cooling and start immediately")
    parser.add_argument("--name")
    parser.add_argument("--root")
    parser.add_argument("--plan-file", dest="plan_file")
    parser.add_argument("--priority", type=int)
    parser.add_argument("--allow-platform", action="store_true")
    parser.add_argument("--project", dest="project_id")
    parser.add_argument("--port", type=int)
    parser.add_argument("--no-open", action="store_true")
    parser.add_argument("--dev", action="store_true")
    parser.add_argument("-h", "--help", action="store_true")
    args = parser.parse_args(argv)
    if args.help or not args.command:
        print(__doc__)
        return 0
    overrides = {}
    for item in args.sets:
        if "=" in item:
            key, _, value = item.partition("=")
            overrides[key.strip()] = value.strip()
    try:
        cfg = load_config(profile=args.profile, cli_overrides=overrides)
    except Exception as exc:
        print("failed to load config: %s" % exc, file=sys.stderr)
        return 1
    if args.command == "dry-run":
        return cmd_tick(cfg, args, dry_run=True)
    handler = COMMANDS.get(args.command)
    if handler is None:
        print("unknown command %r\n%s" % (args.command, __doc__),
              file=sys.stderr)
        return 2
    return handler(cfg, args)


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
